# Check for changed files and filter out certain suffixes
if git diff --cached --name-only | grep -E '\.(ts|tsx)$' | grep -q .; then
  echo "Running checks..."
  pnpm fmt
  pnpm fmt.check
  pnpm lint
  pnpm test
  pnpm build
  git update-index --again

else
  echo "No relevant changes, skipping checks."
fi

