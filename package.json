{
  "name": "@linden_quan/don",
  "version": "0.1.0",
  "description": "personal financial management app",
  "engines": {
    "node": ">=20.3.0"
  },
  "packageManager": "pnpm@9.12.1",
  "type": "module",
  "keywords": ["qwik", "vite", "financial management"],
  "files": ["src/", "public/"],
  "author": "Linden Quan",
  "license": "ISC",
  "private": false,
  "scripts_annotation": "SSR build/dev relies on SSG build/dev.",
  "scripts": {
    "install": "pnpm husky",
    "build": "pnpm run clean && qwik build",
    "build.client": "vite build && vite build -c adapters/static/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "clean": "rm -rf dist coverage server tmp",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "serve": "node scripts/serve.js",
    "start": "pnpm run dev",
    "check": "biome check",
    "check.fix": "biome check --write",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.3",
    "@builder.io/qwik": "^1.9.1",
    "@builder.io/qwik-city": "^1.9.1",
    "@types/eslint": "9.6.1",
    "@types/node": "22.7.4",
    "@typescript-eslint/eslint-plugin": "8.8.1",
    "@typescript-eslint/parser": "8.8.1",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "9.12.0",
    "eslint-plugin-qwik": "^1.9.1",
    "husky": "^9.1.6",
    "prettier": "3.3.3",
    "send": "^0.19.0",
    "typescript": "^5.6.2",
    "undici": "^6.19.8",
    "vite": "5.4.8",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.2"
  }
}
